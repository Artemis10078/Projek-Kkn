# Salin file ini menjadi ".env" lalu isi dengan kredensial milik kamu sendiri.
# JANGAN commit file ".env" ke git (sudah ada di .gitignore).

# === SUPABASE ===
# Didapat dari: Dashboard Supabase -> Project Settings -> API
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# === MIDTRANS ===
# Didapat dari: Dashboard Midtrans -> Settings -> Access Keys
# Client Key boleh dipakai di frontend (public).
VITE_MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxx

# Set "true" jika sudah pakai akun production Midtrans, "false" untuk sandbox/testing
VITE_MIDTRANS_IS_PRODUCTION=false
